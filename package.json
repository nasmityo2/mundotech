{
  "name": "mundotech-ecommerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate deploy",
    "security:versions": "node scripts/check-security-versions.mjs",
    "security:api-guards": "node scripts/check-api-origin-guards.mjs",
    "security:audit:runtime": "npm audit --omit=dev --audit-level=high",
    "security:audit:dev": "bash scripts/audit-dev-dependencies.sh",
    "security:sbom": "bash scripts/generate-sbom.sh",
    "deploy:vps": "bash scripts/deploy-vps.sh",
    "db:seed:reviews": "tsx scripts/seed-reviews.ts",
    "db:migrate:images": "tsx scripts/migrate-legacy-images-to-r2.ts",
    "test:r2-private": "node scripts/verify-private-r2.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "db:e2e:reset": "tsx scripts/e2e-reset-db.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.19",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@sentry/nextjs": "^10.65.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.0.8",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.7.0",
    "react-hook-form": "^7.81.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.17",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.2",
    "@img/sharp-linux-x64": "0.35.3",
    "@next/swc-darwin-arm64": "^16.2.10",
    "@next/swc-darwin-x64": "^16.2.10",
    "@next/swc-linux-x64-gnu": "^16.2.10",
    "@next/swc-win32-x64-msvc": "^16.2.10"
  },
  "browserslist": [
    "chrome >= 111",
    "safari >= 16",
    "firefox >= 111",
    "edge >= 111"
  ]
