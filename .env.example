# Cloudinary — copia a .env.local (no subas .env.local a git)
#
# Opción recomendada: una sola URL (Dashboard → API Keys → "Environment variable")
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Necesario para el widget de subida en el admin (mismo cloud name que en la URL):
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
#
# Alternativa sin CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
#
# Para CldUploadWidget: crea un upload preset sin firmar en el panel (ej. ml_default).

# Resend — correos transaccionales (solo servidor; nunca NEXT_PUBLIC_)
# https://resend.com/api-keys
# RESEND_API_KEY=re_...

# Redes MundoTech (home + footer)
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/tu_cuenta
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/tu_pagina
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/584121471338

# URL pública del sitio (sin / final). Necesaria para returnUrl y webhook de Binance Pay en producción.
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# OAuth Google (opcional). Si faltan, el botón "Continuar con Google" no aparece en /login.
# Consola: https://console.cloud.google.com/apis/credentials — tipo "Web" y URIs autorizados: https://tu-dominio/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google Maps — ficha real del negocio (recomendado). En Maps: busca tu tienda → Compartir → Copiar vínculo.
# Sin esto se usa una búsqueda por texto (dirección + nombre).
# NEXT_PUBLIC_GOOGLE_MAPS_BUSINESS_URL=https://www.google.com/maps/place/...
# Embed (opcional): Compartir → Insertar mapa → copiar solo la URL dentro de src=\"...\"
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Binance Pay (comercio) — https://merchant.binance.com → Developers → API
# BINANCE_PAY_API_KEY=
# BINANCE_PAY_API_SECRET=
# Opcional: solo si Binance te indica otro host
# BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
# Moneda fiat para el cobro (precios del catálogo deben ser consistentes con esta moneda, p. ej. USD)
# BINANCE_PAY_FIAT_CURRENCY=USD
