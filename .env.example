# ════════════════════════════════════════════════════════════════════════
# MUNDOTECH ECOMMERCE — Variables de entorno
# Copia este archivo a .env (local/VPS) y completa los valores reales.
# NUNCA subas .env a git.
# NUNCA uses prefijo NEXT_PUBLIC_ para secretos (API keys, tokens, passwords).
# ════════════════════════════════════════════════════════════════════════

# ── Base de datos (OBLIGATORIO) ──────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
# Conexión directa a Postgres (sin PgBouncer). Obligatoria para `prisma migrate deploy`.
# Si usas pooler en DATABASE_URL (ej. ?pgbouncer=true), DIRECT_URL debe apuntar al puerto nativo 5432.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# ── NextAuth (OBLIGATORIO) ───────────────────────────────────────────────
# Genera un secret aleatorio: openssl rand -base64 32
NEXTAUTH_SECRET=cambia-esto-por-un-secret-aleatorio-de-32-chars
# URL pública de tu app (sin / final). En dev: http://localhost:3000
# En producción: https://mundotechve.com
NEXTAUTH_URL=http://localhost:3000

# ── Migración one-shot de imágenes legacy → R2 (opcional) ───────────────
# Hostname del CDN anterior cuyas URLs aún están en BD. Solo para:
#   npm run db:migrate:images -- --dry-run
# LEGACY_IMAGE_CDN_HOST=

# ── Cloudflare R2 — almacenamiento de imágenes (OBLIGATORIO en runtime prod) ─
# Endpoint S3 de escritura (solo subida; NO es la URL pública de lectura).
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mundotech-media
# Dominio público de lectura (r2.dev o custom domain en Cloudflare). Sin slash final.
R2_PUBLIC_BASE_URL=https://cdn.tu-dominio.com
# Mismo valor que R2_PUBLIC_BASE_URL — necesario para validar URLs en el admin (Client Components).
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://cdn.tu-dominio.com

# ── Resend — correos transaccionales (RECOMENDADO; sin ellas no se envían emails) ─
# Solo servidor; nunca NEXT_PUBLIC_. https://resend.com/api-keys
# Si faltan, lib/resend.tsx omite el envío con log (no tumba la app).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend. DEBE ser un dominio propio de la tienda
# (mejora la entregabilidad y evita que los correos parezcan spam). Se usa como
# "From" en todos los correos. Acepta solo el correo (se antepone "MundoTech")
# o el formato completo "MundoTech <noreply@tu-dominio.com>".
# Dominio verificado en Resend (https://resend.com/domains):
RESEND_FROM_ADDRESS=noreply@mundotechve.com
# Correo de atención real: se usa como Reply-To en los correos y como contacto público.
NEXT_PUBLIC_CONTACT_EMAIL=ventas@mundotechve.com

# ── Despliegue — proxy y entorno (RECOMENDADO en producción) ─────────────
# Controla cómo se extrae la IP real del cliente para rate limiting.
# Valores: "vercel" | "cloudflare" | (vacío = sin proxy de confianza configurado)
# DEPLOYMENT_ENV=vercel

# ── Upstash Redis (RECOMENDADO en producción multi-instancia) ─────────────
# Para rate limiting global entre instancias serverless.
# https://console.upstash.com → crear base de datos Redis
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxx

# ── Binance Pay (comercio) ───────────────────────────────────────────────
# https://merchant.binance.com → Developers → API
# BINANCE_PAY_API_KEY=
# BINANCE_PAY_API_SECRET=
# ID de recepción visible en el checkout del cliente
# NEXT_PUBLIC_MUNDOTECH_BINANCE_PAY_ID=
# URL del código QR de Binance (imagen pública)
# NEXT_PUBLIC_MUNDOTECH_BINANCE_QR_URL=
# Opcional: solo si Binance te indica otro host
# BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
# Moneda fiat para el cobro (USD recomendado)
# BINANCE_PAY_FIAT_CURRENCY=USD

# ── OAuth Google (opcional) ──────────────────────────────────────────────
# Si faltan, el botón "Continuar con Google" no aparece en /login.
# Consola: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Redes sociales MundoTech (opcionales) ────────────────────────────────
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/tu_cuenta
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/tu_pagina
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/584121471338

# ── URL pública del sitio ────────────────────────────────────────────────
# Sin / final. Usada en canonicals, sitemap, OG y enlaces en correos.
NEXT_PUBLIC_SITE_URL=https://mundotechve.com

# ── Google Search Console (recomendado en producción) ────────────────────
# Código del meta tag de verificación (Search Console → Propiedad → Verificación
# por etiqueta HTML). Solo el valor del atributo content, no la etiqueta entera.
# Si falta, el meta de verificación no se emite (no afecta al resto del SEO).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Email de contacto público ────────────────────────────────────────────
# NEXT_PUBLIC_CONTACT_EMAIL=ventas@tu-dominio.com

# ── Google Maps ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_MAPS_BUSINESS_URL=https://www.google.com/maps/place/...
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# ── Google Analytics 4 (opcional) ────────────────────────────────────────
# gtag.js se carga con Consent Mode v2 (todo denegado por defecto); los eventos
# de e-commerce (view_item, add_to_cart, begin_checkout, purchase, etc. —
# lib/ga4.ts) son no-op si esta variable falta.
# CÓMO ACTIVARLO: 1) crea una propiedad GA4 en https://analytics.google.com
# (Administrar → Crear propiedad → flujo de datos Web → mundotechve.com),
# 2) copia el "ID de medición" (G-XXXXXXXXXX), 3) añádelo aquí y en el .env
# del VPS, 4) rebuild + deploy (es variable NEXT_PUBLIC_, va en el bundle).
# NEXT_PUBLIC_GA4_ID=

# ── Cloudflare — purga de caché post-deploy (opcional, recomendado) ─────
# Si ambas existen (en /etc/mundotech/mundotech.env del VPS), scripts/deploy-vps.sh
# purga la caché de la zona tras cada deploy para que ningún HTML viejo quede
# apuntando a chunks retirados. Token con permiso "Zone → Cache Purge".
# CF_ZONE_ID=
# CF_API_TOKEN=

# ── Cron jobs (OBLIGATORIO en producción VPS) ───────────────────────────
# El crontab del sistema envía Authorization: Bearer <CRON_SECRET> al invocar
# /api/cron/*. En el VPS se configura en /etc/mundotech/mundotech.env y systemd.
# Genera uno: openssl rand -hex 32
# Ejemplo sugerido (NO reutilizar en prod — genera el tuyo):
# CRON_SECRET=a7f3c9e2b81d4f6058a2e7c1d9b0f4a6e8c2d5f7a9b1c3e5d7f9a2b4c6d8e0f2
CRON_SECRET=

# ── Datos de la tienda en correos (opcionales; tienen defaults reales) ───
# NEXT_PUBLIC_CONTACT_PHONES=0412-1471338 · 0414-5709470
# NEXT_PUBLIC_STORE_ADDRESS=Carrera 21 con esquina calle 21, Centro, Barquisimeto 3001, estado Lara
# NEXT_PUBLIC_INSTAGRAM_HANDLE=@Mundotech39
