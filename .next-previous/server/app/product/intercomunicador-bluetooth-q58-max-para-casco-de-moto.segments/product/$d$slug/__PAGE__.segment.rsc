14:["$","div",null,{"className":"mt-5","children":["$","$L20",null,{"product":{"id":"cmqcph2270000wb5nqw81ivig","slug":"intercomunicador-bluetooth-q58-max-para-casco-de-moto","name":"Intercomunicador Bluetooth Q58 Max para Casco de Moto","description":"Intercomunicador Bluetooth Q58 Max para casco de moto: habla hasta 500 m, comparte música, escucha radio FM y mira la pantalla LCD. Resistente al agua, envíos a toda Venezuela.\r\n\r\nEl Q58 Max convierte tu casco en un centro de comunicación y entretenimiento. Conéctate con otro motorizado hasta a 500 metros, atiende llamadas sin soltar el manillar y disfruta tu música en alta definición, llueva o truene.\r\n\r\nCaracterísticas principales:\r\n• Intercomunicador Bluetooth de hasta 500 m entre dos cascos.\r\n• Compartir música: escucha la misma canción con tu acompañante o compañero de ruta.\r\n• Radio FM incorporada con pantalla LCD para ver emisora, volumen y batería.\r\n• Sonido HD con cancelación de ruido de viento, ideal para autopista.\r\n• Iluminación RGB y diseño resistente al agua (IPX, apto para lluvia).\r\n• Batería de larga duración y carga rápida; manos libres por comando.\r\n• Compatible con cualquier casco (integral, abierto o modular).\r\n\r\nIdeal para motorizados, delivery, grupos de rodada y viajes largos.","price":40,"originalPrice":50,"stock":2,"category":"Accesorios","brand":"Q58","images":["https://pub-9522140e021e458080a7be88f582adf1.r2.dev/products/intercomunicador-bluetooth-q58-max-para-casco-de-moto-451b2da1.webp","https://pub-9522140e021e458080a7be88f582adf1.r2.dev/products/intercomunicador-bluetooth-q58-max-para-casco-de-moto-ac6e0f0c.webp"],"sku":"MT-MQDDBFK8MDE","specs":null,"updatedAt":"$D2026-06-22T04:09:42.528Z","media":[{"id":"cmqddbfmr0001rt5nn3zq935f","productId":"cmqcph2270000wb5nqw81ivig","type":"VIDEO","url":"https://pub-9522140e021e458080a7be88f582adf1.r2.dev/products/intercomunicador-bluetooth-q58-max-para-casco-de-moto-b74c96e0.mp4","posterUrl":"https://pub-9522140e021e458080a7be88f582adf1.r2.dev/products/intercomunicador-bluetooth-q58-max-para-casco-de-moto-451b2da1.webp","sortOrder":0},{"id":"cmqddbfmr0002rt5nhvdk6hq6","productId":"cmqcph2270000wb5nqw81ivig","type":"IMAGE","url":"https://pub-9522140e021e458080a7be88f582adf1.r2.dev/products/intercomunicador-bluetooth-q58-max-para-casco-de-moto-ac6e0f0c.webp","posterUrl":null,"sortOrder":1}],"image":"https://pub-9522140e021e458080a7be88f582adf1.r2.dev/products/intercomunicador-bluetooth-q58-max-para-casco-de-moto-451b2da1.webp","details":{}}}]}]
