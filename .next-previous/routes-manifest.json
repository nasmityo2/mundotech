{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/favicon.ico",
      "destination": "/icon.svg",
      "statusCode": 307,
      "regex": "^(?!/_next)/favicon\\.ico(?:/)?$"
    },
    {
      "source": "/privacidad",
      "destination": "/privacy-policy",
      "statusCode": 308,
      "regex": "^(?!/_next)/privacidad(?:/)?$"
    },
    {
      "source": "/terminos",
      "destination": "/terms-of-service",
      "statusCode": 308,
      "regex": "^(?!/_next)/terminos(?:/)?$"
    },
    {
      "source": "/envios",
      "destination": "/shipping-policy",
      "statusCode": 308,
      "regex": "^(?!/_next)/envios(?:/)?$"
    },
    {
      "source": "/about",
      "destination": "/nosotros",
      "statusCode": 308,
      "regex": "^(?!/_next)/about(?:/)?$"
    },
    {
      "source": "/quienes-somos",
      "destination": "/nosotros",
      "statusCode": 308,
      "regex": "^(?!/_next)/quienes-somos(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    },
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/_next/static(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/icon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ],
      "regex": "^/icon\\.svg(?:/)?$"
    }
  ],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
