generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────────────────────
enum ProductMediaType {
  IMAGE
  VIDEO
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  sku           String?  @unique
  description   String?
  price         Float
  originalPrice Float?
  stock         Int      @default(0)
  category      String
  brand         String?
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  views         ProductView[]
  media         ProductMedia[]

  @@index([slug])
  @@index([category])
  @@index([sku])
}

model ProductMedia {
  id         String           @id @default(cuid())
  productId  String
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       ProductMediaType
  url        String
  posterUrl  String?
  sortOrder  Int              @default(0)

  @@index([productId, sortOrder])
}

model Category {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  imageUrl   String?
  isFeatured Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isFeatured])
}

model Promotion {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  discountText String?
  imageUrl     String?
  bgColor      String   @default("#FFD700")
  link         String   @default("/productos")
  active       Boolean  @default(true)
  order        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, order])
}

model Banner {
  id        String   @id @default(cuid())
  type      String
  imageUrl  String
  title     String?
  subtitle  String?
  label     String?
  ctaText   String?
  tagText   String?   
  link      String?  @default("/productos")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

// ─────────────────────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("client")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders               Order[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @default(autoincrement()) @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customerId      String?
  customer        User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String?
  customerPhone   String?

  items           OrderItem[]

  total           Float
  /** Tasa Bs/USD usada al crear el pedido. Si es null, `total` e ítems están en USD (pedidos antiguos). */
  exchangeRateUsdBs Float?
  status          String      @default("Pendiente")
  paymentMethod   String

  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZipCode String      @default("N/A")
  shippingCountry String      @default("Venezuela")

  customerIdNumber    String?
  paymentBank         String?
  paymentHolderIdNumber String?
  paymentHolderPhone  String?
  paymentReference    String?
  paymentProofUrl     String?

  // Tracking de envío (opcional, se setea cuando el pedido pasa a "Enviado")
  trackingNumber   String?
  trackingCarrier  String?
  trackingPhotoUrl String?
  trackingUrl      String?
  shippedAt        DateTime?
  /** Fecha en que se validó el pago (Validar Pago / equivalente). Para reportes por día de cobro. */
  paidAt           DateTime?

  notes           String?
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  productName String
  quantity    Int
  price       Float
  imageUrl    String?
  @@index([orderId])
  @@index([productId])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sessionId String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}