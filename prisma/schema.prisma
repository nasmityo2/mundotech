generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────────────────────
enum ProductMediaType {
  IMAGE
  VIDEO
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  sku           String?  @unique
  description   String?
  price         Float
  originalPrice Float?
  stock         Int      @default(0)
  category      String
  brand         String?
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  views         ProductView[]
  media         ProductMedia[]
  reviews       Review[]

  @@index([slug])
  @@index([category])
  @@index([sku])
}

model ProductMedia {
  id         String           @id @default(cuid())
  productId  String
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       ProductMediaType
  url        String
  posterUrl  String?
  sortOrder  Int              @default(0)

  @@index([productId, sortOrder])
}

model Category {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  imageUrl   String?
  isFeatured Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isFeatured])
}

model Promotion {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  discountText String?
  imageUrl     String?
  bgColor      String   @default("#FFD700")
  link         String   @default("/productos")
  active       Boolean  @default(true)
  order        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, order])
}

model Banner {
  id        String   @id @default(cuid())
  type      String
  imageUrl  String
  title     String?
  subtitle  String?
  label     String?
  ctaText   String?
  tagText   String?   
  link      String?  @default("/productos")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

// ─────────────────────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("client")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders               Order[]
  passwordResetTokens  PasswordResetToken[]
  reviews              Review[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @default(autoincrement()) @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customerId      String?
  customer        User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String?
  customerPhone   String?

  items           OrderItem[]

  total           Float
  /** Tasa Bs/USD usada al crear el pedido. Si es null, `total` e ítems están en USD (pedidos antiguos). */
  exchangeRateUsdBs Float?
  status          String      @default("Pendiente")
  paymentMethod   String

  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZipCode String      @default("N/A")
  shippingCountry String      @default("Venezuela")

  customerIdNumber    String?
  paymentBank         String?
  paymentHolderIdNumber String?
  paymentHolderPhone  String?
  paymentReference    String?
  paymentProofUrl     String?

  // Tracking de envío (opcional, se setea cuando el pedido pasa a "Enviado")
  trackingNumber   String?
  trackingCarrier  String?
  trackingPhotoUrl String?
  trackingUrl      String?
  shippedAt        DateTime?
  /** Fecha en que se validó el pago (Validar Pago / equivalente). Para reportes por día de cobro. */
  paidAt           DateTime?

  // Cupón aplicado (descuento calculado en el servidor, congelado en Bs).
  /** Código del cupón aplicado al pedido (en mayúsculas). Null si no se usó cupón. */
  couponCode       String?
  /** Descuento aplicado por el cupón, en Bs (misma moneda que `total`). */
  couponDiscount   Float?

  // Auditoría de verificación de pago (quién validó/rechazó y por qué).
  /** Email del admin que validó o rechazó el pago. Para trazabilidad. */
  paymentVerifiedBy      String?
  /** Motivo de rechazo del pago, si el pedido fue cancelado por pago no válido. */
  paymentRejectionReason String?

  notes           String?
  couponRedemption CouponRedemption?
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  productName String
  quantity    Int
  price       Float
  imageUrl    String?
  @@index([orderId])
  @@index([productId])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sessionId String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// RESEÑAS / VALORACIONES
// ─────────────────────────────────────────────────────────────
// status: 'PENDING' | 'APPROVED' | 'REJECTED' — valores en lib/definitions.ts (ReviewStatus).
model Review {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  authorName  String
  rating      Int
  title       String?
  comment     String

  status           String   @default("PENDING")
  verifiedPurchase Boolean  @default(false)
  adminReply       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, status])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// CUPONES DE DESCUENTO
// ─────────────────────────────────────────────────────────────
// discountType: 'PERCENT' | 'FIXED' — valores en lib/definitions.ts (CouponDiscountType).
// FIXED se expresa en USD; PERCENT es un porcentaje 1-100.
model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Float
  /** Compra mínima en USD (subtotal) para que aplique el cupón. */
  minPurchase   Float    @default(0)
  /** Tope máximo de descuento en USD (solo aplica a PERCENT). Null = sin tope. */
  maxDiscount   Float?
  /** Usos totales permitidos. Null = ilimitado. */
  maxUses       Int?
  usedCount     Int      @default(0)
  /** Usos máximos por usuario registrado. Null = sin límite por usuario. */
  perUserLimit  Int?
  startsAt      DateTime?
  expiresAt     DateTime?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  redemptions   CouponRedemption[]

  @@index([active])
  @@index([code])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String?
  /** Descuento aplicado, en Bs (misma moneda que Order.total). */
  discount  Float
  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}