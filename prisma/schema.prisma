generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String         @id @default(cuid())
  name          String
  slug          String?        @unique
  sku           String?        @unique
  description   String?
  price         Float
  originalPrice Float?
  stock         Int            @default(0)
  category      String
  brand         String?
  images        String[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  /// * Especificaciones técnicas: [{ name: string, value: string }]. Null = sin specs cargadas.
  specs         Json?
  media         ProductMedia[]
  views         ProductView[]
  reviews       Review[]
  cartItems     CartItem[]

  @@index([slug])
  @@index([category])
  @@index([sku])
}

model ProductMedia {
  id        String           @id @default(cuid())
  productId String
  type      ProductMediaType
  url       String
  posterUrl String?
  sortOrder Int              @default(0)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Category {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  imageUrl   String?
  isFeatured Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isFeatured])
}

model Promotion {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  discountText String?
  imageUrl     String?
  bgColor      String   @default("#FFD700")
  link         String   @default("/productos")
  active       Boolean  @default(true)
  order        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, order])
}

model Banner {
  id        String   @id @default(cuid())
  type      String
  imageUrl  String
  title     String?
  subtitle  String?
  label     String?
  ctaText   String?
  tagText   String?
  link      String?  @default("/productos")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  name                String?
  role                String               @default("client")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  reviews             Review[]
  savedAddresses      SavedAddress[]
  abandonedCarts      AbandonedCart[]
  cart                Cart?
}

// ─────────────────────────────────────────────────────────────────────────────
// LIBRO DE DIRECCIONES
// ─────────────────────────────────────────────────────────────────────────────
model SavedAddress {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  alias          String
  firstName      String
  lastName       String
  idNumber       String
  phoneNumber    String
  shippingMethod String   @default("tienda")
  mrwState       String?
  mrwOffice      String?
  isDefault      Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id                     String            @id @default(cuid())
  orderNumber            Int               @unique @default(autoincrement())
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  customerId             String?
  customerName           String
  customerEmail          String?
  customerPhone          String?
  total                  Float
  status                 String            @default("Pendiente")
  paymentMethod          String
  shippingAddress        String
  shippingCity           String
  shippingState          String
  shippingZipCode        String            @default("N/A")
  shippingCountry        String            @default("Venezuela")
  customerIdNumber       String?
  paymentBank            String?
  paymentHolderIdNumber  String?
  paymentHolderPhone     String?
  paymentReference       String?
  paymentProofUrl        String?
  notes                  String?
  shippedAt              DateTime?
  trackingCarrier        String?
  trackingNumber         String?
  trackingPhotoUrl       String?
  trackingUrl            String?
  /// * Tasa Bs/USD usada al crear el pedido. Si es null, `total` e ítems están en USD (pedidos antiguos).
  exchangeRateUsdBs      Float?
  /// * Fecha en que se validó el pago (Validar Pago / equivalente). Para reportes por día de cobro.
  paidAt                 DateTime?
  /// /** Código del cupón aplicado al pedido (en mayúsculas). Null si no se usó cupón.
  couponCode             String?
  /// * Descuento aplicado por el cupón, en Bs (misma moneda que `total`).
  couponDiscount         Float?
  /// * Motivo de rechazo del pago, si el pedido fue cancelado por pago no válido.
  paymentRejectionReason String?
  /// /** Email del admin que validó o rechazó el pago. Para trazabilidad.
  paymentVerifiedBy      String?
  couponRedemption       CouponRedemption?
  customer               User?             @relation(fields: [customerId], references: [id])
  items                  OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  price       Float
  imageUrl    String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  sessionId String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

model Review {
  id               String   @id @default(cuid())
  productId        String
  userId           String?
  authorName       String
  rating           Int
  title            String?
  comment          String
  status           String   @default("PENDING")
  verifiedPurchase Boolean  @default(false)
  adminReply       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id])

  @@index([productId, status])
  @@index([status])
  @@index([createdAt])
}

model Coupon {
  id            String             @id @default(cuid())
  code          String             @unique
  description   String?
  discountType  String
  discountValue Float
  /// * Compra mínima en USD (subtotal) para que aplique el cupón.
  minPurchase   Float              @default(0)
  /// * Tope máximo de descuento en USD (solo aplica a PERCENT). Null = sin tope.
  maxDiscount   Float?
  /// * Usos totales permitidos. Null = ilimitado.
  maxUses       Int?
  usedCount     Int                @default(0)
  /// * Usos máximos por usuario registrado. Null = sin límite por usuario.
  perUserLimit  Int?
  startsAt      DateTime?
  expiresAt     DateTime?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  redemptions   CouponRedemption[]

  @@index([active])
  @@index([code])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  orderId   String   @unique
  userId    String?
  /// * Descuento aplicado, en Bs (misma moneda que Order.total).
  discount  Float
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
}

model RestockSubscription {
  id         String    @id @default(cuid())
  email      String
  productId  String
  /// * Fecha en que se envió el aviso. Null = aún pendiente.
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([email, productId])
  @@index([productId, notifiedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CARRITO ABANDONADO
// status: 'PENDING' | 'EMAILED_24H' | 'EMAILED_72H' | 'RECOVERED' | 'OPTED_OUT'
// ─────────────────────────────────────────────────────────────────────────────
model AbandonedCart {
  id             String    @id @default(cuid())
  email          String
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Items serializados: AbandonedCartItem[] { id, name, slug, price, quantity, image }
  items          Json
  totalUsd       Float
  /// Token único para el enlace de recuperación / opt-out.
  recoveryToken  String    @unique @default(cuid())
  status         String    @default("PENDING")
  /// Fecha del último email de abandono enviado.
  emailSentAt    DateTime?
  /// Última vez que se actualizó el carrito (se usa como T0 para la ventana de 24h/72h).
  lastActivityAt DateTime  @default(now())
  recoveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email, status])
  @@index([status, lastActivityAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CARRITO PERSISTENTE (sincronizado con cuenta)
// ─────────────────────────────────────────────────────────────────────────────
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

enum ProductMediaType {
  IMAGE
  VIDEO
}
