generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String         @id @default(cuid())
  name          String
  /// PRD-065: slug obligatorio (backfill en migración `prd_infra_datos_cache`).
  slug          String         @unique
  sku           String?        @unique
  description   String?
  /// PRD-204: Decimal(12,2) para evitar errores de redondeo binario en sumas.
  price         Decimal        @db.Decimal(12, 2)
  /// Costo base en USD (lo que el negocio paga). Usado para auto-calcular price.
  /// SENSIBLE: nunca exponer en catálogo/API pública. Solo selects admin.
  cost          Decimal?       @db.Decimal(12, 2)
  originalPrice Decimal?       @db.Decimal(12, 2)
  /// Margen de ganancia % específico de este producto. Null = usar el margen global.
  /// Se usa para recalcular `price` desde `cost` al cambiar el factor BCV–Binance globalmente.
  profitMarginPct Decimal?       @db.Decimal(6, 2)
  /// Tasa BCV–Binance vigente cuando se fijó el precio. Usada para reescalar
  /// productos de precio manual al recalcular. Null = aún sin calibrar.
  priceBaseFactor  Decimal? @db.Decimal(6,2)
  stock         Int            @default(0)
  /// PRD-124: categoría por nombre (string); enlazada a Category por slug/nombre en la app.
  category      String
  brand         String?
  images        String[]
  /// PRD-064/121: despublicar/soft-delete sin borrar — preserva carritos,
  /// historial de pedidos y URLs. DEPENDENCIA-01 (getProducts) / 02 (checkout)
  /// / 05 (admin): filtrar `isActive: true` en listados públicos y compra.
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  /// * Especificaciones técnicas: [{ name: string, value: string }]. Null = sin specs cargadas.
  specs         Json?
  media         ProductMedia[]
  views         ProductView[]
  reviews       Review[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([slug])
  @@index([category])
  @@index([sku])
  @@index([isActive])
}

model ProductMedia {
  id        String           @id @default(cuid())
  productId String
  type      ProductMediaType
  url       String
  posterUrl String?
  sortOrder Int              @default(0)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  imageUrl    String?
  isFeatured  Boolean   @default(false)
  order       Int       @default(0)
  /// P85: texto plano (sin HTML) editable desde admin. Usado en meta description,
  /// CollectionPage JSON-LD y el hero de la categoría. Null = fallback genérico.
  description String?
  /// P85: título SEO opcional (≤ 70 chars). Usado en <title> y JSON-LD name.
  /// Null = se genera automáticamente a partir de `name`.
  seoTitle         String?
  /// TODO-MC-01 (cerrado): override del ID de categoría Google (taxonomía oficial).
  /// Si está definido, el feed usa este valor directamente; si es null, cae en
  /// el mapa automático de lib/google-product-categories.ts.
  googleCategoryId Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isFeatured])
}

model Promotion {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  discountText String?
  imageUrl     String?
  bgColor      String   @default("#FFD700")
  link         String   @default("/productos")
  active       Boolean  @default(true)
  order        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, order])
}

model Banner {
  id        String   @id @default(cuid())
  type      String
  imageUrl  String
  title     String?
  subtitle  String?
  label     String?
  ctaText   String?
  tagText   String?
  link      String?  @default("/productos")
  /// Punto focal para object-position del hero (recorte en móvil).
  focalPoint String? @default("center")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  name                String?
  /// PRD-127: roles canónicos en MAYÚSCULAS ('CLIENT' | 'ADMIN').
  role                String               @default("CLIENT")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  /// PRD-173/240: timestamp del último cambio de contraseña. El callback JWT
  /// deriva la huella (pwv) del hash bcrypt; cuando el hash cambia la huella
  /// difiere y todas las sesiones activas se invalidan en ≤5 min.
  passwordChangedAt   DateTime?
  /// PRD-014/089: nuevo email pendiente de confirmar antes de ser promovido.
  pendingEmail        String?
  /// PRD-014/089: token de un solo uso enviado al nuevo correo (hash SHA-256).
  emailChangeToken    String?              @unique
  /// PRD-014/089: expiración del token de cambio de email (1 hora).
  emailChangeTokenExpiry DateTime?
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  reviews             Review[]
  savedAddresses      SavedAddress[]
  abandonedCarts      AbandonedCart[]
  cart                Cart?
}

// ─────────────────────────────────────────────────────────────────────────────
// LIBRO DE DIRECCIONES
// ─────────────────────────────────────────────────────────────────────────────
model SavedAddress {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  alias          String
  firstName      String
  lastName       String
  idNumber       String
  phoneNumber    String
  shippingMethod String   @default("tienda")
  mrwState       String?
  mrwOffice      String?
  officeAddress  String?   // ZOOM: dirección física de la oficina (snapshot). MRW no la usa.
  officeCity     String?   // ZOOM: ciudad de la oficina (snapshot). MRW no la usa.
  isDefault      Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id                     String            @id @default(cuid())
  orderNumber            Int               @unique @default(autoincrement())
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  customerId             String?
  customerName           String
  customerEmail          String?
  customerPhone          String?
  /// PRD-204: Decimal(12,2) — sin errores de redondeo binario en totales acumulados.
  total                  Decimal           @db.Decimal(12, 2)
  /// PRD-122: valores válidos = OrderStatus de lib/definitions.ts. No se puede usar
  /// enum Prisma sin romper runtime de 02/05 ('En Proceso' y 'Pendiente verificación
  /// Binance' llevan espacios → el cliente devolvería otros literales). La migración
  /// `prd_infra_datos_cache` añade CHECK "Order_status_valid" a nivel de BD.
  status                 String            @default("Pendiente")
  paymentMethod          String
  shippingAddress        String
  shippingCity           String
  shippingState          String
  shippingZipCode        String            @default("N/A")
  shippingCountry        String            @default("Venezuela")
  customerIdNumber       String?
  paymentBank            String?
  paymentHolderIdNumber  String?
  paymentHolderPhone     String?
  paymentReference       String?
  paymentProofUrl        String?
  notes                  String?
  shippedAt              DateTime?
  trackingCarrier        String?
  trackingNumber         String?
  trackingPhotoUrl       String?
  trackingUrl            String?
  /// * Tasa Bs/USD usada al crear el pedido. Si es null, `total` e ítems están en USD (pedidos antiguos).
  /// PRD-204: Decimal(12,4) para preservar decimales significativos de la tasa.
  exchangeRateUsdBs      Decimal?          @db.Decimal(12, 4)
  /// * Fecha en que se validó el pago (Validar Pago / equivalente). Para reportes por día de cobro.
  paidAt                 DateTime?
  /// /** Código del cupón aplicado al pedido (en mayúsculas). Null si no se usó cupón.
  couponCode             String?
  /// * Descuento aplicado por el cupón, en Bs (misma moneda que `total`). PRD-204: Decimal.
  couponDiscount         Decimal?          @db.Decimal(12, 2)
  /// * Motivo de rechazo del pago, si el pedido fue cancelado por pago no válido.
  paymentRejectionReason String?
  /// /** Email del admin que validó o rechazó el pago. Para trazabilidad.
  paymentVerifiedBy      String?
  couponRedemption       CouponRedemption?
  customer               User?             @relation(fields: [customerId], references: [id])
  items                  OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
  /// PRD-125: lookups de pedidos por email (guest, soporte, cron) sin full scan.
  @@index([customerEmail])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  /// PRD-204: Decimal(12,2).
  price       Decimal    @db.Decimal(12, 2)
  imageUrl    String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// PRD-123: FK real hacia Product. Restrict = no se puede borrar (hard-delete)
  /// un producto con historial de pedidos — usar `isActive: false` (soft-delete).
  /// Preserva la auditoría financiera. DEPENDENCIA-05: deleteProductAction debe
  /// mostrar error amable / ofrecer despublicar.
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProductView {
  id         String   @id @default(cuid())
  productId  String
  sessionId  String?
  viewBucket String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([sessionId, productId, viewBucket])
  @@index([productId])
  @@index([createdAt])
}

model Review {
  id               String       @id @default(cuid())
  productId        String
  userId           String?
  authorName       String
  rating           Int
  title            String?
  comment          String
  /// PRD-122: enum nativo — los literales 'PENDING'/'APPROVED'/'REJECTED' no
  /// cambian en runtime, así que el resto de segmentos compila sin cambios.
  status           ReviewStatus @default(PENDING)
  verifiedPurchase Boolean      @default(false)
  adminReply       String?
  photos           String[]     @default([])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// PRD-217: SetNull explícito — borrar un usuario anonimiza sus reseñas
  /// (queda authorName) en vez de bloquear o perder el historial.
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
  @@index([productId, status])
  @@index([status])
  @@index([createdAt])
}

model Coupon {
  id            String             @id @default(cuid())
  code          String             @unique
  description   String?
  discountType  String
  /// PRD-204: Decimal(12,2).
  discountValue Decimal            @db.Decimal(12, 2)
  /// * Compra mínima en USD (subtotal) para que aplique el cupón.
  minPurchase   Decimal            @default(0) @db.Decimal(12, 2)
  /// * Tope máximo de descuento en USD (solo aplica a PERCENT). Null = sin tope.
  maxDiscount   Decimal?           @db.Decimal(12, 2)
  /// * Usos totales permitidos. Null = ilimitado.
  maxUses       Int?
  usedCount     Int                @default(0)
  /// * Usos máximos por usuario registrado. Null = sin límite por usuario.
  perUserLimit  Int?
  startsAt      DateTime?
  expiresAt     DateTime?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  redemptions   CouponRedemption[]

  @@index([active])
  @@index([code])
}

model CouponRedemption {
  id          String    @id @default(cuid())
  couponId    String
  orderId     String    @unique
  userId      String?
  /// * Slot 1..perUserLimit por usuario; impide canjes concurrentes duplicados.
  perUserSlot Int?
  /// * Descuento aplicado, en Bs (misma moneda que Order.total). PRD-204: Decimal.
  discount    Decimal   @db.Decimal(12, 2)
  /// * Marca de auditoría al revertir canje (cancelación); null = canje activo.
  revertedAt  DateTime?
  createdAt   DateTime  @default(now())
  coupon      Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Índice único parcial (couponId, userId, perUserSlot) WHERE revertedAt IS NULL:
  // ver migración 20260614170000_coupon_redemption_partial_unique_index.
  @@index([couponId])
  @@index([userId])
}

model RestockSubscription {
  id         String    @id @default(cuid())
  email      String
  productId  String
  /// * Fecha en que se envió el aviso. Null = aún pendiente.
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([email, productId])
  @@index([productId, notifiedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CARRITO ABANDONADO
// status: 'PENDING' | 'EMAILED_24H' | 'EMAILED_72H' | 'RECOVERED' | 'OPTED_OUT'
// ─────────────────────────────────────────────────────────────────────────────
model AbandonedCart {
  id             String    @id @default(cuid())
  email          String
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Items serializados: AbandonedCartItem[] { id, name, slug, price, quantity, image }
  items          Json
  /// PRD-204: Decimal(12,2).
  totalUsd       Decimal    @db.Decimal(12, 2)
  /// PRD-178: SHA-256 (hex) del token de recuperación/opt-out. El token en claro
  /// solo existe en el email enviado; se genera y rota en lib/abandoned-cart.ts.
  recoveryTokenHash String @unique
  status         String    @default("PENDING")
  /// Fecha del último email de abandono enviado.
  emailSentAt    DateTime?
  /// Última vez que se actualizó el carrito (se usa como T0 para la ventana de 24h/72h).
  lastActivityAt DateTime  @default(now())
  recoveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email, status])
  @@index([status, lastActivityAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CARRITO PERSISTENTE (sincronizado con cuenta)
// ─────────────────────────────────────────────────────────────────────────────
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  /// PRD-232: antes Cascade — borrar un producto vaciaba ítems de carritos de
  /// clientes sin aviso. Restrict bloquea el hard-delete si hay carritos con el
  /// producto: el flujo correcto es despublicar (`isActive: false`).
  /// DEPENDENCIA-05: deleteProductAction debe manejar el error y sugerirlo.
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

model VideoJob {
  id        String   @id @default(cuid())
  status    String   @default("PROCESSING") // PROCESSING | READY | FAILED
  videoUrl  String
  posterUrl String?
  width     Int?
  height    Int?
  durationS Int?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// PRD-122: estados de moderación de reseñas (coincide 1:1 con ReviewStatus de
/// lib/definitions.ts — mismos literales en runtime).
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
